{
	"name": "gtfish04",
	"displayName": "gtfish04_select-highlight",
	"description": "Highlight all occurrences of selected text with customized color scheme. Enhanced fork with swapped light/dark theme colors for improved visibility using cochineal-based palette.",
	"publisher": "gtfish1988",
	"version": "0.1.0",
	"engines": {
		"vscode": "^1.30.0"
	},
	"icon": "images/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish04_select-highlight"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"*"
	],
	"main": "./out/src/extension",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"postinstall": "node ./node_modules/vscode/bin/install",
		"test": "npm run compile && node ./node_modules/vscode/bin/test"
	},
	"devDependencies": {
		"typescript": "^2.5.2",
		"vscode": "^1.1.5",
		"mocha": "^3.5.0",
		"@types/node": "^7.0.43",
		"@types/mocha": "^2.2.42"
	},
	"bugs": {
		"url": "https://github.com/tgaochn/vscodeExtensions/issues"
	},
	"homepage": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish04_select-highlight"
}

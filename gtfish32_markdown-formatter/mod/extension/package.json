{
	"name": "gtfish32-markdown-formatter",
	"displayName": "gtfish32_markdown-formatter",
	"description": "Advanced Markdown formatter with CJK-English auto-spacing, LaTeX-to-Unicode symbol conversion, code block language auto-wrapping, and HTML/Markdown bidirectional conversion. Extensively rewritten fork of markdownformat with 5 custom commands, modular architecture, and delimiter-aware formatting.",
	"version": "0.8.26",
	"publisher": "gtfish1988",
	"engines": {
		"vscode": "^1.21.0"
	},
	"icon": "images/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish32_markdown-formatter"
	},
	"categories": [
		"Programming Languages",
		"Formatters",
		"Other"
	],
	"activationEvents": [
		"onLanguage:markdown"
	],
	"main": "./extension",
	"contributes": {
		"commands": [
			{
				"command": "extension.reFormat",
				"title": "GF32 MdFormat: 格式化MD"
			},
			{
				"command": "extension.reFormat_html2md",
				"title": "GF32 MdFormat: 格式化MD_html2md"
			},
			{
				"command": "extension.reFormat_md2html",
				"title": "GF32 MdFormat: 格式化MD_md2html"
			},
			{
				"command": "extension.copyEncodedRelativePathOfCurrentFile",
				"title": "GF32 MdFormat: 复制当前文件的相对路径"
			},
			{
				"command": "extension.copyEncodedRelativePathOfCurrentFileWithTitle",
				"title": "GF32 MdFormat: 复制当前文件的相对路径_带标题"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "extension.reFormat",
					"when": "editorLangId == markdown && !editorReadonly",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"postinstall": "node ./node_modules/vscode/bin/install",
		"test": "node ./node_modules/vscode/bin/test"
	},
	"devDependencies": {
		"@types/mocha": "^2.2.42",
		"@types/node": "^7.0.43",
		"eslint": "^4.11.0",
		"jest": "^29.7.0",
		"typescript": "^2.6.1",
		"vscode": "^1.1.6"
	}
}

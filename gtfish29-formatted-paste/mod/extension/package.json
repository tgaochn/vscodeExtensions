{
	"name": "gtfish29-formatted-paste",
	"displayName": "gtfish29-formatted-paste",
	"description": "Paste clipboard content with leading and trailing whitespace automatically trimmed. Custom utility extension for clean paste operations.",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.97.0"
	},
	"publisher": "gtfish1988",
	"categories": [
		"Other"
	],
	"license": "MIT",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [
			{
				"command": "formatted-paste.trimmed-paste",
				"title": "Formatted Paste (Trimmed)"
			}
		],
		"keybindings": [
			{
				"command": "formatted-paste.trimmed-paste",
				"key": "ctrl+shift+v",
				"mac": "cmd+shift+v",
				"when": "editorTextFocus"
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish29-formatted-paste/mod/extension"
	},
	"bugs": {
		"url": "https://github.com/tgaochn/vscodeExtensions/issues"
	},
	"homepage": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish29-formatted-paste/mod/extension",
	"icon": "images/icon.png"
}

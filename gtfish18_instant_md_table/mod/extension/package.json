{
	"name": "gtfish18-instant-md-table",
	"displayName": "gtfish18-instant-md-table",
	"description": "Generate Markdown tables instantly from selected text or clipboard data. Enhanced fork with improved table formatting and keybinding support.",
	"version": "0.0.3",
	"publisher": "gtfish1988",
	"engines": {
		"vscode": "^1.24.0"
	},
	"categories": [
		"Other",
		"Programming Languages"
	],
	"galleryBanner": {
		"color": "#0A6A6A",
		"theme": "dark"
	},
	"activationEvents": [
		"onCommand:markdown.generateTable",
		"onCommand:markdown.generateTableWithAlignment"
	],
	"main": "./extension",
	"contributes": {
		"commands": [
			{
				"command": "markdown.generateTable",
				"title": "Markdown: New Table"
			},
			{
				"command": "markdown.generateTableWithAlignment",
				"title": "Markdown: New Table With Alignment"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"postinstall": "node ./node_modules/vscode/bin/install",
		"test": "npm run compile && node ./node_modules/vscode/bin/test"
	},
	"devDependencies": {
		"typescript": "^2.6.1",
		"vscode": "^1.1.6",
		"tslint": "^5.8.0",
		"@types/node": "^7.0.43",
		"@types/mocha": "^2.2.42"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish18_instant_md_table/mod/extension"
	},
	"icon": "images/icon.png",
	"bugs": {
		"url": "https://github.com/tgaochn/vscodeExtensions/issues"
	},
	"homepage": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish18_instant_md_table/mod/extension"
}

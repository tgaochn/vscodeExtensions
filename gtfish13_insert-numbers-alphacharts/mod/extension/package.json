{
	"name": "gtfish13",
	"version": "0.1.0",
	"publisher": "gtfish1988",
	"displayName": "gtfish13_insert-numbers-alphacharts",
	"description": "Insert sequential numbers, letters, and custom character sequences at multiple cursors. Enhanced fork with alphabetic character support and extended keybindings.",
	"keywords": [
		"sequences",
		"numbers",
		"insert",
		"alphachars"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/tgaochn/vscodeExtensions/tree/master/gtfish13_insert-numbers-alphacharts"
	},
	"engines": {
		"vscode": "^1.49.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:extension.insertNums",
		"onCommand:extension.insertNums.showHistory"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "insertnums",
			"properties": {
				"insertnums.historyLimit": {
					"type": "number",
					"default": 30,
					"description": "Maximum number of historical records, 0 is unlimited"
				},
				"insertnums.editHistory": {
					"type": "boolean",
					"default": false,
					"description": "Picked item from PickHistory is editable (default: false)"
				}
			}
		},
		"commands": [
			{
				"command": "extension.insertNums",
				"title": "GF13: Insert Numbers & Alphachars"
			},
			{
				"command": "extension.insertNums.showHistory",
				"title": "GF13: Show Insert History"
			}
		],
		"keybindings": [
			{
				"command": "extension.insertNums",
				"key": "ctrl+alt+.",
				"mac": "cmd+alt+.",
				"when": "editorTextFocus"
			},
			{
				"command": "extension.insertNums.showHistory",
				"key": "ctrl+alt+,",
				"mac": "cmd+alt+,",
				"when": "editorTextFocus"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^7.0.2",
		"@types/node": "^13.13.21",
		"@types/vscode": "^1.49.0",
		"@typescript-eslint/eslint-plugin": "^2.34.0",
		"@typescript-eslint/parser": "^2.34.0",
		"eslint": "^6.8.0",
		"glob": "^7.1.6",
		"mocha": "^7.2.0",
		"typescript": "^3.9.7",
		"vscode-test": "^1.4.0"
	},
	"dependencies": {
		"@types/d3-format": "^1.3.1",
		"d3-format": "^1.4.5"
	},
	"icon": "images/icon.png",
	"galleryBanner": {
		"color": "#5757ff",
		"theme": "dark"
	}
}
